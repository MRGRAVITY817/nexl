;; stdlib/test — Unit testing primitives.
;;
;; This file is the source of truth for `test` module documentation.
;; The Rust implementation lives in crates/nexl-stdlib/src/test.rs.
;;
;; Typical usage pattern:
;;
;;   (test/register! "my test" (fn [] (assert! (= 1 1) "1 = 1")))
;;   (test/run-registered)
;;
;; Use `nexl test file.nx` to run a test file and get a pass/fail report.

(defn register!
  """
  Register a named test in the thread-local test registry.

  The test is not executed immediately. Call `test/run-registered` (or
  run the file with `nexl test`) to execute all registered tests.

  ## Parameters
  - `name` — test name shown in the output as `Str`.
  - `thunk` — zero-argument function `(Fn [] Any)` containing assertions.

  ## Returns
  `Unit`

  ## Examples

  ```nexl
  (test/register! \"addition is commutative\"
    (fn []
      (assert! (= (+ 1 2) (+ 2 1)) \"1+2 = 2+1\")))

  (test/register! \"str/split round-trips\"
    (fn []
      (let [original \"a,b,c\"
            parts    (str/split original \",\")
            rejoined (str/join parts \",\")]
        (assert! (= original rejoined) \"round-trip failed\"))))
  ```

  ## See Also
  - `test/run-registered` — execute all registered tests
  - `test/clear-registry!` — discard registered tests without running
  """
  [name thunk]
  (native "test/register!" name thunk))

(defn run-registered
  """
  Run all tests registered via `test/register!` and print a report.

  Tests are run in registration order. Each test's thunk is called in
  isolation. A test passes if the thunk returns without error. A test
  fails if an assertion fails or the thunk panics.

  Prints one line per test: `PASS name` or `FAIL name: message`.
  Returns `Unit`.

  ## Returns
  `Unit`

  ## Examples

  ```nexl
  (test/register! \"sanity\" (fn [] (assert! true \"always passes\")))
  (test/run-registered)
  ;; PASS sanity

  ;; Full test file pattern:
  (test/register! \"test-a\" (fn [] ...))
  (test/register! \"test-b\" (fn [] ...))
  (test/run-registered)
  ```

  ## See Also
  - `test/register!` — register tests before running
  - `test/clear-registry!` — reset after running
  """
  []
  (native "test/run-registered"))

(defn clear-registry!
  """
  Discard all tests in the thread-local registry without running them.

  Useful between test suites run in the same process, or after using
  `test/run-registered` when you want a clean slate.

  ## Returns
  `Unit`

  ## Examples

  ```nexl
  (test/run-registered)
  (test/clear-registry!)
  ;; Registry is now empty
  ```
  """
  []
  (native "test/clear-registry!"))

(defn is
  """
  Assert that `condition` is `true`, failing the test with `msg` if not.

  Equivalent to `assert!` but namespaced under `test/`. Prefer `assert!`
  inside registered test thunks.

  ## Parameters
  - `condition` — `Bool` value to test.
  - `msg` — failure message shown if the assertion fails.

  ## Returns
  `Unit` on success; raises a test failure on false.

  ## Examples

  ```nexl
  (test/is (= result expected) \"result should equal expected\")
  (test/is (> count 0) \"collection should be non-empty\")
  ```
  """
  [condition msg]
  (native "test/is" condition msg))

(defn assert-eq
  """
  Assert that `a` and `b` are structurally equal.

  On failure, the message includes both values for easy debugging.

  ## Parameters
  - `a` — first value.
  - `b` — second value to compare against.

  ## Returns
  `Unit` on success; raises a test failure if `a ≠ b`.

  ## Examples

  ```nexl
  (test/assert-eq (+ 1 2) 3)
  (test/assert-eq (str/upper \"hello\") \"HELLO\")
  (test/assert-eq (filter odd? [1 2 3]) [1 3])
  ```
  """
  [a b]
  (native "test/assert-eq" a b))

(defn fail
  """
  Immediately fail the current test with a message.

  Use when you need to fail a test unconditionally — for example, when
  a code path that should never be reached is reached.

  ## Parameters
  - `msg` — failure message as `Str`.

  ## Returns
  Never (raises a test failure).

  ## Examples

  ```nexl
  (match result
    (Ok _)  unit
    (Err e) (test/fail (str \"Unexpected error: \" e)))

  (when (> count max)
    (test/fail (str/format \"count {} exceeds max {}\" [count max])))
  ```
  """
  [msg]
  (native "test/fail" msg))

(defn skip
  """
  Mark the current test as skipped with an explanatory message.

  ## Parameters
  - `msg` — skip reason as `Str`.

  ## Returns
  A `Skip` ADT value (printed in the test report as `SKIP`).

  ## Examples

  ```nexl
  (test/register! \"network test\"
    (fn []
      (when (= (env/get \"CI\") (Some \"true\"))
        (test/skip \"skipped in CI\"))))
  ```
  """
  [msg]
  (native "test/skip" msg))

(defn check
  """
  Run a property-based test by calling `pred` on each value in `samples`.

  Returns `(Ok Unit)` if all calls return `true`, or `(Err Str)` with
  the first failing value.

  ## Parameters
  - `pred` — `(Fn [Any] Bool)` property to test.
  - `samples` — `(Vec Any)` of sample inputs.

  ## Returns
  `(Result Unit Str)`

  ## Examples

  ```nexl
  (test/check (fn [x] (= (+ x 0) x)) (range 100))
  ; => (Ok Unit)  — additive identity holds for 0..99

  (test/check (fn [s] (= s (str/trim (str s)))) [\"a\" \" b\" \"c \"])
  ```
  """
  [pred samples]
  (native "test/check" pred samples))

(defn run-tests
  """
  Run a list of `[name thunk]` pairs and print a report.

  An alternative to `test/register!` + `test/run-registered` when you
  want to define tests inline without the global registry.

  ## Parameters
  - `tests` — `(Vec [Str (Fn [] Any)])` — name–thunk pairs.

  ## Returns
  `Unit`

  ## Examples

  ```nexl
  (test/run-tests
    [[\"addition\"   (fn [] (assert! (= (+ 1 2) 3) \"1+2=3\"))]
     [\"subtraction\" (fn [] (assert! (= (- 5 3) 2) \"5-3=2\"))]])
  ```
  """
  [tests]
  (native "test/run-tests" tests))

;; ── Phase 2 Macros (M27) ─────────────────────────────────────────────────────
;;
;; The forms below replace the corresponding special forms in nexl-eval's
;; eval.rs. They are registered by the macro expander before user code is
;; evaluated, so `(throws? ...)`, `(setup ...)`, etc. expand to primitive
;; calls rather than being dispatched as special forms.

(defmacro-syntax throws?
  """
  Assert that the body raises an exception, optionally matching a type hint.

  `(throws? body ...)` — passes if body raises any error.
  `(throws? [TypeHint] body ...)` — passes if the error message contains the
  source text of `TypeHint` (e.g. `[DivisionByZero]`).

  ## Examples

  ```nexl
  (throws? (panic "boom"))
  (throws? [DivisionByZero] (/ 1 0))
  ```

  ## See Also
  - `is` — general assertion form
  - `deftest` — define a named test
  """
  [(_ [type-hint] body ...)
   `(match (test/try-call! (fn [] ~@body))
      (Ok _)  (test/fail "expected exception, got none")
      (Err e) (if (str/contains? e ~(syntax-str type-hint))
                unit
                (test/fail (str "expected error containing \""
                               ~(syntax-str type-hint)
                               "\", got: " e))))]
  [(_ body ...)
   `(match (test/try-call! (fn [] ~@body))
      (Ok _)  (test/fail "expected exception, got none")
      (Err _) unit)])

(defmacro-syntax setup
  """
  Register a setup hook that runs before each test in the current `describe` scope.

  Body forms are collected into a zero-argument function automatically.

  ## Examples

  ```nexl
  (describe "DB tests"
    (setup (db/reset!))
    (deftest "insert" ...))
  ```

  ## See Also
  - `teardown` — runs after each test
  - `setup-all` — runs once before all tests in the scope
  """
  [(_ body ...) `(test/setup-push! (fn [] ~@body))])

(defmacro-syntax teardown
  """
  Register a teardown hook that runs after each test in the current `describe` scope.

  Body forms are collected into a zero-argument function automatically.

  ## Examples

  ```nexl
  (describe "DB tests"
    (teardown (db/close! conn))
    (deftest "query" ...))
  ```

  ## See Also
  - `setup` — runs before each test
  - `teardown-all` — runs once after all tests in the scope
  """
  [(_ body ...) `(test/teardown-push! (fn [] ~@body))])

(defmacro-syntax setup-all
  """
  Register a setup hook that runs once before all tests in the current `describe` scope.

  Body forms are collected into a zero-argument function automatically.

  ## Examples

  ```nexl
  (describe "Suite"
    (setup-all (io/println "suite start"))
    (deftest "first" ...))
  ```

  ## See Also
  - `teardown-all` — runs once after all tests
  - `setup` — runs before each individual test
  """
  [(_ body ...) `(test/setup-all-push! (fn [] ~@body))])

(defmacro-syntax teardown-all
  """
  Register a teardown hook that runs once after all tests in the current `describe` scope.

  Body forms are collected into a zero-argument function automatically.

  ## Examples

  ```nexl
  (describe "Suite"
    (teardown-all (io/println "suite end"))
    (deftest "last" ...))
  ```

  ## See Also
  - `setup-all` — runs once before all tests
  - `teardown` — runs after each individual test
  """
  [(_ body ...) `(test/teardown-all-push! (fn [] ~@body))])

(defmacro-syntax is-match
  """
  Assert that `expr` matches `pattern`, then run optional body assertions
  with the pattern's bindings in scope.

  `(is-match pattern expr)` — fails if expr does not match pattern.
  `(is-match pattern expr :when guard)` — additionally fails if guard is false.
  `(is-match pattern expr body ...)` — runs body forms if the pattern matches.

  The body can contain further `is` or `is-match` assertions, making
  it easy to chain structural checks without deep nesting at the call site.

  ## Examples

  ```nexl
  (is-match (Ok id) (create-user db "alice"))

  (is-match (Ok user) (find-user db 1)
    (is (= (:name user) "alice"))
    (is (> (:age user) 0)))

  (is-match (Some x) (find-item items) :when (> x 0))
  ```

  ## See Also
  - `is` — simple boolean assertion
  - `throws?` — assert that an expression raises
  """
  [(_ pattern expr :when guard body ...)
   `(match ~expr
      ~pattern (if ~guard
                 (do ~@body unit)
                 (test/fail (str "is-match: guard failed for: "
                                ~(syntax-str expr))))
      _ (test/fail (str "is-match: "
                        ~(syntax-str expr)
                        " did not match pattern")))]
  [(_ pattern expr body ...)
   `(match ~expr
      ~pattern (do ~@body unit)
      _ (test/fail (str "is-match: "
                        ~(syntax-str expr)
                        " did not match pattern")))])

(defmacro-syntax describe
  """
  Group tests under a named scope.

  The label is prepended to each test name inside the block, producing
  output like `"Outer > Inner > test name"`. Scopes can be nested.

  `(describe "label" body ...)` — plain grouping.
  `(describe "label" :let [bindings ...] body ...)` — with fixture bindings
  shared across all nested tests.

  `setup` / `teardown` / `setup-all` / `teardown-all` hooks registered
  inside a `describe` are automatically cleaned up when the block exits.

  ## Examples

  ```nexl
  (describe "User domain"
    (describe "creation"
      (deftest "valid name" ...))
    (describe "deletion"
      (deftest "removes record" ...)))

  (describe "DB suite" :let [db (make-test-db)]
    (setup (db/reset! db))
    (deftest "insert" ...))
  ```

  ## See Also
  - `deftest` — define an individual test
  - `setup` / `teardown` — per-test lifecycle hooks
  """
  ;; `:let bindings` — `bindings` is bound to the whole vector `[name val ...]`
  ;; and spliced directly into the inner `let` form.
  [(_ label :let bindings body ...)
   `(do
      (test/describe-push! ~label)
      (let [setup-depth#    (test/setup-stack-len)
            teardown-depth# (test/teardown-stack-len)]
        (let ~bindings
          ~@body)
        (each [_ (range (- (test/setup-stack-len) setup-depth#))]
          (test/setup-pop!))
        (each [_ (range (- (test/teardown-stack-len) teardown-depth#))]
          (test/teardown-pop!)))
      (test/describe-pop!))]
  [(_ label body ...)
   `(do
      (test/describe-push! ~label)
      (let [setup-depth#    (test/setup-stack-len)
            teardown-depth# (test/teardown-stack-len)]
        ~@body
        (each [_ (range (- (test/setup-stack-len) setup-depth#))]
          (test/setup-pop!))
        (each [_ (range (- (test/teardown-stack-len) teardown-depth#))]
          (test/teardown-pop!)))
      (test/describe-pop!))])

(defmacro-syntax is
  """
  Assert that an expression is true, with power-assert style failure messages.

  `(is expr)` — fails with `"assertion failed: <source>"` if expr is false.
  `(is (op lhs rhs))` — evaluates both sides and shows them on failure:
    `"assertion failed: (= x y)\n  left: 1\n  right: 2"`
  `(is (pred val))` — shows the predicate and value on failure.
  `(is expr "msg")` — prepends a custom message.
  `(is actual matcher)` — runs a matcher function returning `(Ok _)` or `(Err msg)`.

  ## Examples

  ```nexl
  (is (= result 42))
  (is (> count 0))
  (is (str/starts-with? name "alice"))
  (is valid? "value should be valid")
  ```

  ## See Also
  - `is-match` — pattern-matching assertion
  - `throws?` — assert that an expression raises
  """
  ;; Binary op: (is (op lhs rhs)) — evaluates both sides, reports them on failure
  [(_ (op lhs rhs))
   `(let [l# ~lhs r# ~rhs]
      (when (not (~op l# r#))
        (test/fail (str "assertion failed: (" ~(syntax-str op)
                        " " ~(syntax-str lhs) " " ~(syntax-str rhs)
                        ")\n  left:  " l#
                        "\n  right: " r#))))]
  ;; 1-arg predicate: (is (pred val))
  [(_ (pred val))
   `(let [v# ~val]
      (when (not (~pred v#))
        (test/fail (str "assertion failed: (" ~(syntax-str pred)
                        " " ~(syntax-str val)
                        ")\n  " ~(syntax-str val) ": " v#))))]
  ;; 2-arg: message string OR matcher function — dispatch at runtime
  [(_ actual mm)
   `(let [mm# ~mm]
      (if (test/str? mm#)
        ;; message form: (is expr "msg")
        (when (not ~actual)
          (test/fail (str mm# ": " ~(syntax-str actual))))
        ;; matcher form: (is actual matcher-fn) — matcher returns (Ok _) or (Err msg)
        (match (mm# ~actual)
          (Err e) (test/fail e)
          _ unit)))]
  ;; Simple bool
  [(_ expr)
   `(when (not ~expr)
      (test/fail (str "assertion failed: " ~(syntax-str expr))))])

(defmacro-syntax deftest
  """
  Define a named test and register it in the current test suite.

  `(deftest "name" body ...)` — registers body as a test thunk.
  `(deftest "name" {:tags [...] :skip "reason" :focus true :flaky N} body ...)` — with metadata.

  The test name is prefixed with the current `describe` stack, e.g.
  `"Outer > Inner > name"`. Setup/teardown hooks active at definition time
  are captured and run around the body automatically.

  ## Metadata keys
  - `:skip "reason"` — mark the test as skipped; body is not evaluated.
  - `:focus true` — run only focused tests when any test has `:focus`.
  - `:tags [:tag1 :tag2]` — filter with `nexl test --tags tag1`.
  - `:flaky N` — retry up to N times before reporting failure (default 3).

  ## Examples

  ```nexl
  (deftest "addition is commutative"
    (is (= (+ 1 2) (+ 2 1))))

  (deftest "slow network call" {:tags [:integration] :flaky 3}
    (is-match (Ok _) (http/get "https://example.com")))

  (deftest "pending feature" {:skip "not implemented yet"}
    (is false))
  ```

  ## See Also
  - `describe` — group tests under a named scope
  - `is` — assertion form used inside tests
  """
  ;; With metadata map
  [(_ name {:& meta} body ...)
   `(let [full#   (str (test/describe-prefix) ~name)
          setup#  (test/current-setup-hooks)
          teardn# (test/current-teardown-hooks)]
      (match (:skip ~meta)
        (None) (test/register! full# (fn []
                 (each [h setup#] (h))
                 ~@body
                 (each [h (reverse teardn#)] (h))))
        reason# (test/register! full# (fn [] (test/skip reason#))))
      (match (:focus ~meta) (None) unit _ (test/focus-register! full#))
      (match (:tags ~meta)  (None) unit tags# (test/tags-register! full# tags#))
      (match (:flaky ~meta) (None) unit n# (test/flaky-register! full# n#)))]
  ;; Without metadata
  [(_ name body ...)
   `(let [full#   (str (test/describe-prefix) ~name)
          setup#  (test/current-setup-hooks)
          teardn# (test/current-teardown-hooks)]
      (test/register! full# (fn []
        (each [h setup#] (h))
        ~@body
        (each [h (reverse teardn#)] (h)))))])

(defmacro-syntax bench
  """
  Define a benchmark.

  `(bench "name" body ...)` — 1000 iterations, 10 warmup rounds.
  `(bench "name" :iterations N :warmup W body ...)` — explicit config.

  In bench mode (`nexl bench file.nx`): registers body as a benchmark thunk
  and reports median/p99 timing. Outside bench mode: evaluates body once and
  discards the result (zero overhead in test runs).

  ## Examples

  ```nexl
  (bench "string concatenation"
    (str/join ["hello" " " "world"]))

  (bench "json encode" :iterations 5000 :warmup 100
    (json/encode {:name "alice" :age 30}))
  ```

  ## See Also
  - `check` — property-based testing
  - `deftest` — functional test definition
  """
  [(_ name :iterations iters :warmup wu body ...)
   `(if (test/is-bench-mode?)
      (test/bench-register! ~name ~iters ~wu (fn [] ~@body))
      (do ~@body unit))]
  [(_ name body ...)
   `(if (test/is-bench-mode?)
      (test/bench-register! ~name 1000 10 (fn [] ~@body))
      (do ~@body unit))])

;; ── Phase 6: check — property-based testing ──────────────────────────────────

;; Helper: generate n seeds by successive LCG steps from start.
;; Returns a Vec of n Int seeds.
(defn gen/seed-seq
  [start n]
  (loop [i    0
         seed start
         acc  []]
    (if (= i n)
      acc
      (let [next-seed (gen/lcg-next seed)]
        (recur (+ i 1) next-seed (append acc next-seed))))))

;; Internal helper: run a single-binding property check.
;; - name-str:  string label for the binding (used in failure messages)
;; - gen:       generator function `(fn [seed] -> value)`
;; - n:         number of trials (Int)
;; - seed:      initial RNG seed (Int)
;; - body-fn:   `(fn [val] body...)` — property under test
(defn test/check-run!
  [name-str gen n seed body-fn]
  (let [overrides (test/take-seed-overrides)]
    ;; Run override seeds first (replayed failures from .test-seeds)
    (each [trial-seed overrides]
      (let [val (gen trial-seed)]
        (match (test/try-call! (fn [] (body-fn val)))
          (Ok _) unit
          (Err e) (do (test/persist-seed! trial-seed)
                      (test/fail (str "check: falsified " name-str "=" val
                                      " (seed " trial-seed "): " e))))))
    ;; Then run fresh random seeds
    (each [trial-seed (gen/seed-seq seed n)]
      (let [val (gen trial-seed)]
        (match (test/try-call! (fn [] (body-fn val)))
          (Ok _) unit
          (Err e) (do (test/persist-seed! trial-seed)
                      (test/fail (str "check: falsified " name-str "=" val
                                      " (seed " trial-seed "): " e))))))))

(defmacro-syntax check
  """
  Property-based test: run body for N randomly generated values.

  `(check [name gen] body ...)` — 100 trials, seed 42.
  `(check [name gen] :num-tests N body ...)` — N trials, seed 42.
  `(check [name gen] :num-tests N :seed S body ...)` — explicit seed.

  `name` is bound to a value produced by `gen` for each trial. If any
  trial fails, the seed is persisted to `.test-seeds` so it is replayed
  on the next run (shrinking-by-replay).

  ## Examples

  ```nexl
  (check [x gen/int]
    (is (= x (+ x 0))))

  (check [s gen/str] :num-tests 500
    (is (= s (str/trim-start (str/trim-end s)))))

  (check [n gen/pos-int] :num-tests 200 :seed 1234
    (is (> (* n 2) n)))
  ```

  ## See Also
  - `gen/int`, `gen/str`, `gen/bool` — built-in generators
  - `deftest` — deterministic test definition
  """
  [(_ [name gen] :num-tests n :seed s body ...)
   `(test/check-run! ~(syntax-str name) ~gen ~n ~s (fn [~name] ~@body))]
  [(_ [name gen] :num-tests n body ...)
   `(test/check-run! ~(syntax-str name) ~gen ~n 42 (fn [~name] ~@body))]
  [(_ [name gen] body ...)
   `(test/check-run! ~(syntax-str name) ~gen 100 42 (fn [~name] ~@body))])

;; ── Phase 7: snap-file! ───────────────────────────────────────────────────────

(defn snap-file!
  """
  Snapshot assertion: compare `expr` against a stored `.snap` file.

  On the first run the snapshot is written automatically. On subsequent
  runs the stringified value of `expr` is compared to the stored content;
  a mismatch fails the test. Outside test mode the call is a no-op.

  Pass `--accept` to `nexl test` to overwrite all snapshots in one pass.

  ## Parameters
  - `name` — snapshot name used as the filename (`__snapshots__/<name>.snap`).
  - `expr` — value whose `str` representation is snapshotted.

  ## Returns
  `Unit`

  ## Examples

  ```nexl
  (snap-file! "user-json" (json/encode user))
  (snap-file! "report"    (render-report data))
  ```

  ## See Also
  - `deftest` — test definition form
  - `is-match` — structural assertion
  """
  [name expr]
  (when (test/test-mode?)
    (let [snap-dir (str (test/snapshots-dir) "/__snapshots__")
          path     (str snap-dir "/" name ".snap")
          actual   (str expr)]
      (io/create-dir-all snap-dir)
      (if (test/accept-mode?)
        (io/write-file path actual)
        (match (io/read-file path)
          (Err _)     (io/write-file path actual)
          (Ok stored) (when (not= stored actual)
                        (test/fail (str "snap-file! \"" name "\" mismatch.\n"
                                        "  expected: " stored "\n"
                                        "  actual:   " actual "\n"
                                        "  (run with --accept to update)"))))))))
